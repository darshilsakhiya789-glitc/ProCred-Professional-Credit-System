# ─────────────────────────────────────────────────────────────
#  ProCred Frontend — Environment Variables
#  Copy this file to .env.local for local dev
#  Add these same keys in Vercel → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────

# Your Render backend URL (no trailing slash)
# Leave EMPTY for local development (Vite proxy handles /api)
# Set this in Vercel for production:
VITE_API_URL=https://procred-professional-credit-system.onrender.com
